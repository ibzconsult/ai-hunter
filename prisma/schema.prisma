generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id               String     @id @default(uuid()) @db.Uuid
  nomeEmpresa      String     @map("nome_empresa") @db.VarChar(255)
  email            String     @unique @db.VarChar(255)
  senhaHash        String     @map("senha_hash") @db.VarChar(255)
  telefone         String?    @db.VarChar(20)
  produtosServicos String?    @map("produtos_servicos")
  icp              String?
  diferenciais     String?
  tomAbordagem     String     @default("consultivo") @map("tom_abordagem") @db.VarChar(20)
  propostaValor    String?    @map("proposta_valor")
  mensagemPadrao   String?    @map("mensagem_padrao")
  apresentacao     String?
  cumprimento1     String?    @map("cumprimento_1")
  cumprimento2     String?    @map("cumprimento_2")
  cumprimento3     String?    @map("cumprimento_3")
  inboundGreeting  String?    @map("inbound_greeting")
  openaiApiKey     String?    @map("openai_api_key") @db.VarChar(255)
  serpapiKey       String?    @map("serpapi_key") @db.VarChar(255)
  notificationPhone String?   @map("notification_phone") @db.VarChar(20)
  agentEnabled     Boolean    @default(false) @map("agent_enabled")
  agentPersona     String?    @map("agent_persona")
  agentGuardrails  String?    @map("agent_guardrails")
  agentCta1        String?    @map("agent_cta_1")
  agentCta2        String?    @map("agent_cta_2")
  agentCta3        String?    @map("agent_cta_3")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  instances        Instance[]
  leads            Lead[]
  pipelines        Pipeline[]
  messages         Message[]
  knowledgeDocs    KnowledgeDoc[]
  followupConfig   FollowupConfig?
  tags             Tag[]
  companies        Company[]
  contacts         Contact[]

  @@map("prospector_tenants")
}

model Pipeline {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome      String   @db.VarChar(100)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  stages    Stage[]

  @@index([tenantId])
  @@map("prospector_pipelines")
}

model Stage {
  id         String   @id @default(uuid()) @db.Uuid
  pipelineId String   @map("pipeline_id") @db.Uuid
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  nome       String   @db.VarChar(100)
  ordem      Int
  tipo       String   @default("custom") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  leads      Lead[]

  @@index([pipelineId, ordem])
  @@map("prospector_stages")
}

model Instance {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label           String?   @db.VarChar(100)
  uazapiUrl       String?   @map("uazapi_url") @db.VarChar(255)
  instanceToken   String?   @map("instance_token") @db.VarChar(255)
  instanceName    String?   @map("instance_name") @db.VarChar(255)
  uazapiSessionId String?   @map("uazapi_session_id") @db.VarChar(255)
  status          String    @default("disconnected") @db.VarChar(20)
  lastQrAt        DateTime? @map("last_qr_at")
  disconnectedAt  DateTime? @map("disconnected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("prospector_instances")
}

model Lead {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  empresa        String?  @db.VarChar(255)
  firstName      String?  @map("first_name") @db.VarChar(100)
  telefone       String?  @db.VarChar(20)
  rating         Decimal? @db.Decimal(3, 1)
  reviews        Int?
  especialidades String?
  site           String?  @db.VarChar(500)
  hasWhatsapp    String?  @map("has_whatsapp") @db.VarChar(20)
  contexto       String?
  siteScrape     String?  @map("site_scrape")
  siteAnalysis   Json?    @map("site_analysis")
  origem         String   @default("manual") @db.VarChar(20)
  disparo        String   @default("nao") @db.VarChar(10)
  ultimaMensagem String?  @map("ultima_mensagem")
  stageId        String?  @map("stage_id") @db.Uuid
  stage          Stage?   @relation(fields: [stageId], references: [id], onDelete: SetNull)
  contactId      String?  @map("contact_id") @db.Uuid
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId      String?  @map("company_id") @db.Uuid
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  respondeu      Boolean  @default(false)
  respondeuEm    DateTime? @map("respondeu_em")
  ultimaResposta String?  @map("ultima_resposta")
  classificacao  String?  @db.VarChar(20)
  interested     Boolean  @default(false)
  isDraft        Boolean  @default(false) @map("is_draft")
  followupCount  Int      @default(0) @map("followup_count")
  lastFollowupAt DateTime? @map("last_followup_at")
  nextFollowupAt DateTime? @map("next_followup_at")
  followupPausedUntil DateTime? @map("followup_paused_until")
  followupManuallyPaused Boolean @default(false) @map("followup_manually_paused")
  interestScore  Int      @default(0) @map("interest_score")
  interestBand   String   @default("cold") @map("interest_band") @db.VarChar(20)
  interestSignals Json?   @map("interest_signals")
  interestUpdatedAt DateTime? @map("interest_updated_at")
  lastInteractionAt DateTime? @map("last_interaction_at")
  createdAt      DateTime @default(now()) @map("created_at")
  messages       Message[]
  tags           LeadTag[]

  @@unique([tenantId, telefone])
  @@index([tenantId])
  @@index([tenantId, disparo])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, nextFollowupAt])
  @@index([tenantId, isDraft])
  @@index([tenantId, interestScore(sort: Desc)])
  @@index([stageId])
  @@index([contactId])
  @@index([companyId])
  @@map("prospector_leads")
}

model Company {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome         String   @db.VarChar(255)
  site         String?  @db.VarChar(500)
  segmento     String?  @db.VarChar(120)
  siteScrape   String?  @map("site_scrape")
  siteAnalysis Json?    @map("site_analysis")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  contacts     Contact[]
  leads        Lead[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("prospector_companies")
}

model Contact {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName  String?  @map("first_name") @db.VarChar(100)
  lastName   String?  @map("last_name") @db.VarChar(100)
  email      String?  @db.VarChar(255)
  phone      String?  @db.VarChar(20)
  role       String?  @db.VarChar(120)
  companyId  String?  @map("company_id") @db.Uuid
  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  isPrimary  Boolean  @default(false) @map("is_primary")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  leads      Lead[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([companyId])
  @@index([companyId, isPrimary])
  @@map("prospector_contacts")
}

model FollowupConfig {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @unique @map("tenant_id") @db.Uuid
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(false)
  maxCount          Int      @default(4) @map("max_count")
  windowStart       String   @default("09:00") @map("window_start") @db.VarChar(5)
  windowEnd         String   @default("18:00") @map("window_end") @db.VarChar(5)
  activeDays        Int[]    @default([1, 2, 3, 4, 5]) @map("active_days")
  timezone          String   @default("America/Sao_Paulo") @db.VarChar(64)
  pauseOnReplyHours Int      @default(48) @map("pause_on_reply_hours")
  instanceId        String?  @map("instance_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  steps             FollowupStep[]

  @@map("prospector_followup_configs")
}

model FollowupStep {
  id         String   @id @default(uuid()) @db.Uuid
  configId   String   @map("config_id") @db.Uuid
  config     FollowupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  order      Int
  delayDays  Int      @map("delay_days")
  type       String   @db.VarChar(30)
  customHint String?  @map("custom_hint")
  docId      String?  @map("doc_id") @db.Uuid

  @@unique([configId, order])
  @@map("prospector_followup_steps")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome      String   @db.VarChar(60)
  color     String   @default("#64748b") @db.VarChar(9)
  createdAt DateTime @default(now()) @map("created_at")
  leads     LeadTag[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("prospector_tags")
}

model LeadTag {
  leadId    String   @map("lead_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([leadId, tagId])
  @@index([tagId])
  @@map("prospector_lead_tags")
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId     String   @map("lead_id") @db.Uuid
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction  String   @db.VarChar(8)
  body       String
  mediaUrl   String?  @map("media_url")
  mediaType  String?  @map("media_type") @db.VarChar(20)
  toolCalled String?  @map("tool_called") @db.VarChar(40)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([leadId, createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("prospector_messages")
}

model KnowledgeDoc {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  titulo        String   @db.VarChar(200)
  descricao     String?
  conteudoTexto String?  @map("conteudo_texto")
  fileUrl       String?  @map("file_url")
  fileType      String?  @map("file_type") @db.VarChar(20)
  sendable      Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("prospector_knowledge_docs")
}
